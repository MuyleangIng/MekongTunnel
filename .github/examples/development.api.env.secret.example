# GitHub Environment secret: API_ENV_FILE
#
# Paste the full content of this file into:
#   GitHub -> Settings -> Environments -> development -> Secrets
#   Name: API_ENV_FILE
#
# This example is for a testing server API service at:
#   /opt/mekong/api/mekong-api
# with:
#   EnvironmentFile=/opt/mekong/api/.env
#
# Replace placeholder values before use.

DATABASE_URL=postgres://CHANGE_ME_USER:CHANGE_ME_PASSWORD@127.0.0.1:5432/CHANGE_ME_DB_NAME?sslmode=disable
JWT_SECRET=change_me_dev_jwt_secret_32_chars_minimum
REFRESH_SECRET=change_me_dev_refresh_secret_32_chars
API_ADDR=:8080

PUBLIC_URL=https://api.testing.example.com
FRONTEND_URL=https://testing.example.com
ALLOWED_ORIGINS=https://testing.example.com
TUNNEL_SERVER_URL=http://127.0.0.1:9090
UPLOAD_DIR=/opt/mekong/uploads

ADMIN_EMAIL=admin@testing.example.com
ADMIN_NAME='Mekong Admin'
ADMIN_PASSWORD=
ADMIN_PLAN=org

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://api.testing.example.com/api/auth/github/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.testing.example.com/api/auth/google/callback

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

RESEND_API_KEY=
RESEND_FROM='Mekong Tunnel <noreply@testing.example.com>'

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ORG=

DB_MAX_CONNS=
DB_MIN_CONNS=
DB_MAX_CONN_LIFETIME=
DB_MAX_CONN_IDLE_TIME=
DB_HEALTH_CHECK_PERIOD=

# Optional Redis. Leave blank if this testing server is single-node.
REDIS_URL=
REDIS_PREFIX=mekong
REDIS_CACHE_TTL=30s
REDIS_DOMAIN_CACHE_TTL=1m
REDIS_NOTIFICATION_CHANNEL=notifications
