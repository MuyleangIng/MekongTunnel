# ============================================================
#  MekongTunnel — Environment Configuration Template
#  Author: Ing Muyleang (អុឹង មួយលៀង) — Ing_Muyleang
#  Open Source by KhmerStack
#
#  USAGE:
#    cp .env.example .env
#    # Edit .env with your real values
#    docker compose up -d
#
#  NEVER commit .env with real secrets to git.
#  This .env.example file IS safe to commit.
# ============================================================


# ----------------------------------------------------------
# DOMAIN  (required)
# Your public domain name.
# Tunnels become subdomains, e.g.:
#   https://happy-tiger-a1b2c3d4.yourdomain.com
# ----------------------------------------------------------
DOMAIN=yourdomain.com


# ----------------------------------------------------------
# SERVER LISTEN ADDRESSES  (optional — defaults shown)
# Only change these if the default ports are taken.
# ----------------------------------------------------------
SSH_ADDR=:22
HTTP_ADDR=:80
HTTPS_ADDR=:443
STATS_ADDR=127.0.0.1:9090
IMAGE_TAG=latest
DEV_IMAGE_TAG=dev


# ----------------------------------------------------------
# CAPACITY LIMITS  (optional)
# Defaults are tuned for aggressive testing:
#   - 1000 active tunnels per IP by default
#   - no total tunnel cap by default
#   - no per-minute connection cap by default
#
# `0` means unlimited for these values.
# ----------------------------------------------------------
MAX_TUNNELS_PER_IP=1000
MAX_TOTAL_TUNNELS=0
MAX_CONNECTIONS_PER_MINUTE=0


# ----------------------------------------------------------
# TRAFFIC / ABUSE LIMITS  (optional)
# `0` disables the limit.
# ----------------------------------------------------------
REQUESTS_PER_SECOND=0
BURST_SIZE=0
RATE_LIMIT_VIOLATIONS_MAX=0
BLOCK_DURATION=0s


# ----------------------------------------------------------
# PAYLOAD LIMITS  (optional)
# Values are in MB. `0` means unlimited.
# ----------------------------------------------------------
MAX_REQUEST_BODY_MB=1024
MAX_RESPONSE_BODY_MB=1024
MAX_WEBSOCKET_TRANSFER_MB=0


# ----------------------------------------------------------
# SSH HOST KEY  (optional — auto-generated if missing)
# Path INSIDE the container.
# Mapped from ./data/host_key via docker-compose volume.
# ----------------------------------------------------------
HOST_KEY_PATH=/host_key


# ----------------------------------------------------------
# TLS CERTIFICATES  (required for HTTPS)
# Paths INSIDE the container.
# Mapped from ./data/certs/ via docker-compose volume.
#
# Get a wildcard cert with:
#   sudo certbot certonly --manual --preferred-challenges dns \
#     -d yourdomain.com -d '*.yourdomain.com'
#
# Then copy to ./data/certs/:
#   cp /etc/letsencrypt/live/yourdomain.com/fullchain.pem data/certs/
#   cp /etc/letsencrypt/live/yourdomain.com/privkey.pem   data/certs/
# ----------------------------------------------------------
TLS_CERT=/certs/fullchain.pem
TLS_KEY=/certs/privkey.pem
