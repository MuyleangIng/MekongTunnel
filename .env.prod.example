# MekongTunnel production env
#
# Supported env files in this repo:
#   cp .env.dev.example .env.dev
#   cp .env.prod.example .env.prod
#   cp .env.compose.dev.example .env.compose.dev
#   cp .env.compose.prod.example .env.compose.prod
#
# This file is for:
#   - ./scripts/run-api.sh prod
#   - ./scripts/deploy-api.sh
#   - ./scripts/deploy-tunnel.sh

# Core API
DATABASE_URL=postgres://CHANGE_ME_USER:CHANGE_ME_PASSWORD@CHANGE_ME_DB_HOST:5432/CHANGE_ME_DB_NAME?sslmode=disable
JWT_SECRET=change_me_production_jwt_secret_32_chars_minimum
REFRESH_SECRET=change_me_production_refresh_secret_32_chars
API_ADDR=:8080

PUBLIC_URL=https://api.angkorsearch.dev
FRONTEND_URL=https://angkorsearch.dev
ALLOWED_ORIGINS=https://angkorsearch.dev
TUNNEL_SERVER_URL=http://127.0.0.1:9090
UPLOAD_DIR=/opt/mekong/uploads

# Optional admin bootstrap at startup
ADMIN_EMAIL=admin@angkorsearch.dev
ADMIN_NAME='Mekong Admin'
ADMIN_PASSWORD=
ADMIN_PLAN=org

# Optional OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://api.angkorsearch.dev/api/auth/github/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.angkorsearch.dev/api/auth/google/callback

# Optional mail delivery
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

RESEND_API_KEY=
RESEND_FROM='Mekong Tunnel <noreply@angkorsearch.dev>'

# Optional Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ORG=

# Optional PostgreSQL pool tuning
DB_MAX_CONNS=
DB_MIN_CONNS=
DB_MAX_CONN_LIFETIME=
DB_MAX_CONN_IDLE_TIME=
DB_HEALTH_CHECK_PERIOD=

# Optional Redis
# Leave REDIS_URL unset if you are still single-node.
REDIS_URL=
REDIS_PREFIX=mekong
REDIS_CACHE_TTL=30s
REDIS_DOMAIN_CACHE_TTL=1m
REDIS_NOTIFICATION_CHANNEL=notifications

# Tunnel edge
# deploy-tunnel.sh uploads this file to /opt/mekongtunnel/.env.prod
DOMAIN=proxy.angkorsearch.dev
SSH_ADDR=:22
HTTP_ADDR=127.0.0.1:8081
HTTPS_ADDR=127.0.0.1:8443
STATS_ADDR=127.0.0.1:9090
HOST_KEY_PATH=/opt/mekongtunnel/host_key
TLS_CERT=/etc/letsencrypt/live/proxy.angkorsearch.dev/fullchain.pem
TLS_KEY=/etc/letsencrypt/live/proxy.angkorsearch.dev/privkey.pem

MAX_TUNNELS_PER_IP=1000
MAX_TOTAL_TUNNELS=0
MAX_CONNECTIONS_PER_MINUTE=0
REQUESTS_PER_SECOND=0
BURST_SIZE=0
RATE_LIMIT_VIOLATIONS_MAX=0
BLOCK_DURATION=0s
MAX_REQUEST_BODY_MB=1024
MAX_RESPONSE_BODY_MB=1024
MAX_WEBSOCKET_TRANSFER_MB=0
