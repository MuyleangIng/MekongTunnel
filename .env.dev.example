# MekongTunnel local development env
#
# Supported env files in this repo:
#   cp .env.dev.example .env.dev
#   cp .env.prod.example .env.prod
#   cp .env.compose.dev.example .env.compose.dev
#   cp .env.compose.prod.example .env.compose.prod
#
# This file is for:
#   - ./scripts/run-api.sh dev
#   - local API work
#   - optional local tunnel work

# Core API
DATABASE_URL=postgres://mekong:mekong_secret@127.0.0.1:5432/mekong?sslmode=disable
JWT_SECRET=change_me_dev_jwt_secret_32_chars_minimum
REFRESH_SECRET=change_me_dev_refresh_secret_32_chars
API_ADDR=:8080

PUBLIC_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
TUNNEL_SERVER_URL=http://localhost:9090

# Optional Telegram bot integration
TELEGRAM_BOT_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=change_me_dev_telegram_webhook_secret
TELEGRAM_BOT_USERNAME=MekongTunnelBot
TELEGRAM_BOT_NAME='Mekong Tunnel'
TELEGRAM_APPROVE_PATH=/telegram-link

UPLOAD_DIR=./uploads

# Optional admin bootstrap at startup
ADMIN_EMAIL=admin@localhost
ADMIN_NAME='Mekong Admin'
ADMIN_PASSWORD=
ADMIN_PLAN=org

# Optional OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=http://localhost:8080/api/auth/github/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:8080/api/auth/google/callback

# Optional mail delivery
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

RESEND_API_KEY=
RESEND_FROM='Mekong Tunnel <noreply@localhost>'

# Optional Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ORG=

# Optional PostgreSQL pool tuning
DB_MAX_CONNS=
DB_MIN_CONNS=
DB_MAX_CONN_LIFETIME=
DB_MAX_CONN_IDLE_TIME=
DB_HEALTH_CHECK_PERIOD=

# Optional Redis
# Leave REDIS_URL unset for single-node local development.
REDIS_URL=
REDIS_PREFIX=mekong
REDIS_CACHE_TTL=30s
REDIS_DOMAIN_CACHE_TTL=1m
REDIS_NOTIFICATION_CHANNEL=notifications

# Optional local tunnel edge
# Extra values here are harmless when you only run the API.
DOMAIN=localhost
SSH_ADDR=:2222
HTTP_ADDR=:8081
HTTPS_ADDR=:8443
STATS_ADDR=127.0.0.1:9090
HOST_KEY_PATH=./host_key
TLS_CERT=./certs/fullchain.pem
TLS_KEY=./certs/privkey.pem

MAX_TUNNELS_PER_IP=1000
MAX_TOTAL_TUNNELS=0
MAX_CONNECTIONS_PER_MINUTE=0
REQUESTS_PER_SECOND=0
BURST_SIZE=0
RATE_LIMIT_VIOLATIONS_MAX=0
BLOCK_DURATION=0s
MAX_REQUEST_BODY_MB=1024
MAX_RESPONSE_BODY_MB=1024
MAX_WEBSOCKET_TRANSFER_MB=0
