# GitHub Environment secret: API_ENV_FILE
#
# Paste the full content of your real API server env file into the GitHub
# secret named API_ENV_FILE if you want GitHub Actions to manage the API
# runtime env and systemd unit.
#
# This file is a safe template only. Replace placeholder values before use.

DATABASE_URL=postgres://CHANGE_ME_USER:CHANGE_ME_PASSWORD@CHANGE_ME_DB_HOST:5432/CHANGE_ME_DB_NAME?sslmode=disable
JWT_SECRET=change_me_production_jwt_secret_32_chars_minimum
REFRESH_SECRET=change_me_production_refresh_secret_32_chars
API_ADDR=:8080

PUBLIC_URL=https://api.example.com
FRONTEND_URL=https://app.example.com
ALLOWED_ORIGINS=https://app.example.com
TUNNEL_SERVER_URL=http://127.0.0.1:9090
UPLOAD_DIR=/opt/mekong/uploads

ADMIN_EMAIL=admin@example.com
ADMIN_NAME='Mekong Admin'
ADMIN_PASSWORD=
ADMIN_PLAN=org

GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://api.example.com/api/auth/github/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.example.com/api/auth/google/callback

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

RESEND_API_KEY=
RESEND_FROM='Mekong Tunnel <noreply@example.com>'

STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ORG=

DB_MAX_CONNS=
DB_MIN_CONNS=
DB_MAX_CONN_LIFETIME=
DB_MAX_CONN_IDLE_TIME=
DB_HEALTH_CHECK_PERIOD=

# Optional Redis for multi-instance cache/pubsub/rate limit support.
REDIS_URL=
REDIS_PREFIX=mekong
REDIS_CACHE_TTL=30s
REDIS_DOMAIN_CACHE_TTL=1m
REDIS_NOTIFICATION_CHANNEL=notifications
