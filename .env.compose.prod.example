# MekongTunnel Docker Compose production env
#
# Copy to .env.compose.prod and use with:
#   docker compose --env-file .env.compose.prod -f docker-compose.yml -f docker-compose.prod.yml up -d

# Core services
POSTGRES_DB=mekong
POSTGRES_USER=mekong
POSTGRES_PASSWORD=change_me_postgres_secret

# Optional Redis
REDIS_URL=redis://redis:6379/0
REDIS_PREFIX=mekong
REDIS_CACHE_TTL=30s
REDIS_DOMAIN_CACHE_TTL=1m
REDIS_NOTIFICATION_CHANNEL=notifications

# API
API_PORT=8080
PUBLIC_URL=https://api.angkorsearch.dev
FRONTEND_URL=https://angkorsearch.dev
ALLOWED_ORIGINS=https://angkorsearch.dev
JWT_SECRET=change_me_production_jwt_secret_32_chars_minimum
REFRESH_SECRET=change_me_production_refresh_secret_32_chars

# Optional admin bootstrap
ADMIN_EMAIL=admin@angkorsearch.dev
ADMIN_NAME=Mekong Admin
ADMIN_PASSWORD=change_me_admin_password
ADMIN_PLAN=org

# Tunnel edge
TUNNEL_SERVER_URL=http://mekong-tunnel:9090
TUNNEL_SSH_PORT=22
TUNNEL_HTTP_PORT=80
TUNNEL_HTTPS_PORT=443
DOMAIN=proxy.angkorsearch.dev
TLS_CERTS_DIR=./deploy/certs

MAX_TUNNELS_PER_IP=1000
MAX_TOTAL_TUNNELS=0
MAX_CONNECTIONS_PER_MINUTE=0
REQUESTS_PER_SECOND=0
BURST_SIZE=0
RATE_LIMIT_VIOLATIONS_MAX=0
BLOCK_DURATION=0s
MAX_REQUEST_BODY_MB=1024
MAX_RESPONSE_BODY_MB=1024
MAX_WEBSOCKET_TRANSFER_MB=0

UPLOAD_DIR=/data/uploads

# Optional OAuth
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_CALLBACK_URL=https://api.angkorsearch.dev/api/auth/github/callback

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.angkorsearch.dev/api/auth/google/callback

# Optional mail delivery
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

RESEND_API_KEY=
RESEND_FROM=Mekong Tunnel <noreply@angkorsearch.dev>

# Optional Stripe billing
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ORG=
