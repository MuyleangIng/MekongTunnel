# MekongTunnel Docker Compose dev env
#
# Copy to .env.compose.dev and use with:
#   docker compose --env-file .env.compose.dev -f docker-compose.yml -f docker-compose.dev.yml up -d

# Core services
POSTGRES_DB=mekong
POSTGRES_USER=mekong
POSTGRES_PASSWORD=mekong_secret
POSTGRES_PORT=5432

# Optional Redis
REDIS_URL=redis://redis:6379/0
REDIS_PORT=6379
REDIS_PREFIX=mekong
REDIS_CACHE_TTL=30s
REDIS_DOMAIN_CACHE_TTL=1m
REDIS_NOTIFICATION_CHANNEL=notifications

# API
API_PORT=8080
API_ADDR=:8080
PUBLIC_URL=http://localhost:8080
FRONTEND_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000
JWT_SECRET=change_me_dev_jwt_secret_32_chars_minimum
REFRESH_SECRET=change_me_dev_refresh_secret_32_chars

# Optional admin bootstrap
ADMIN_EMAIL=admin@localhost
ADMIN_NAME=Mekong Admin
ADMIN_PASSWORD=change_me_admin_password
ADMIN_PLAN=org

# Optional tunnel edge
TUNNEL_SERVER_URL=http://mekong-tunnel:9090
TUNNEL_SSH_PORT=2222
TUNNEL_HTTP_PORT=8081
TUNNEL_HTTPS_PORT=8443
TUNNEL_STATS_PORT=9090
DOMAIN=localhost
TLS_CERTS_DIR=./deploy/certs

# Optional Telegram bot integration
TELEGRAM_BOT_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_SECRET=change_me_dev_telegram_webhook_secret
TELEGRAM_BOT_USERNAME=MekongTunnelBot
TELEGRAM_BOT_NAME=Mekong Tunnel
TELEGRAM_APPROVE_PATH=/telegram-link

MAX_TUNNELS_PER_IP=1000
MAX_TOTAL_TUNNELS=0
MAX_CONNECTIONS_PER_MINUTE=0
REQUESTS_PER_SECOND=0
BURST_SIZE=0
RATE_LIMIT_VIOLATIONS_MAX=0
BLOCK_DURATION=0s
MAX_REQUEST_BODY_MB=1024
MAX_RESPONSE_BODY_MB=1024
MAX_WEBSOCKET_TRANSFER_MB=0

UPLOAD_DIR=/data/uploads

# Optional local tools
ADMINER_PORT=8085
REDIS_COMMANDER_PORT=8086
