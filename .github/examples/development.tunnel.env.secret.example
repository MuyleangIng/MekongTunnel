# GitHub Environment secret: TUNNEL_ENV_FILE
#
# Paste the full content of this file into:
#   GitHub -> Settings -> Environments -> development -> Secrets
#   Name: TUNNEL_ENV_FILE
#
# This example is for a testing server tunnel service at:
#   /opt/mekongtunnel
# with:
#   EnvironmentFile=/opt/mekongtunnel/.env
#
# Replace placeholder values before use.

DOMAIN=testing.example.com
SSH_ADDR=:22
HTTP_ADDR=127.0.0.1:8081
HTTPS_ADDR=127.0.0.1:8443
STATS_ADDR=127.0.0.1:9090

HOST_KEY_PATH=/opt/mekongtunnel/host_key
TLS_CERT=/etc/letsencrypt/live/testing.example.com/fullchain.pem
TLS_KEY=/etc/letsencrypt/live/testing.example.com/privkey.pem

DATABASE_URL=postgres://CHANGE_ME_USER:CHANGE_ME_PASSWORD@127.0.0.1:5432/CHANGE_ME_DB_NAME?sslmode=disable

# Optional Redis. Leave blank if this testing server is single-node.
REDIS_URL=
REDIS_PREFIX=mekong
REDIS_CACHE_TTL=30s
REDIS_DOMAIN_CACHE_TTL=1m
REDIS_NOTIFICATION_CHANNEL=notifications

MAX_TUNNELS_PER_IP=1000
MAX_TOTAL_TUNNELS=0
MAX_CONNECTIONS_PER_MINUTE=0
REQUESTS_PER_SECOND=0
BURST_SIZE=0
RATE_LIMIT_VIOLATIONS_MAX=0
BLOCK_DURATION=0s
MAX_REQUEST_BODY_MB=1024
MAX_RESPONSE_BODY_MB=1024
MAX_WEBSOCKET_TRANSFER_MB=0
