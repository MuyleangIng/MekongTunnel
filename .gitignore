# ── Force-include this file itself ───────────────────────────────────────────
!.gitignore

# ══════════════════════════════════════════════════════════════════════════════
#  GO  (compiled binaries — always build via Makefile into bin/)
# ══════════════════════════════════════════════════════════════════════════════
bin/
/mekong
/mekong-api
/api
*.exe

# SSH host key (generated at runtime — contains private key)
host_key

# TLS certificates
certs/

# ══════════════════════════════════════════════════════════════════════════════
#  JUNK / SCRATCH FILES
# ══════════════════════════════════════════════════════════════════════════════
random.txt
index.html

# ══════════════════════════════════════════════════════════════════════════════
#  SECRETS / ENVIRONMENT
# ══════════════════════════════════════════════════════════════════════════════
.env
.env.*
!.env.dev.example
!.env.prod.example
!.env.compose.dev.example
!.env.compose.prod.example

# ══════════════════════════════════════════════════════════════════════════════
#  RUNTIME DATA
# ══════════════════════════════════════════════════════════════════════════════
data/
data-dev/

# ══════════════════════════════════════════════════════════════════════════════
#  VS CODE EXTENSION  (mekong-vscode-extension/)
# ══════════════════════════════════════════════════════════════════════════════
mekong-vscode-extension/node_modules/
mekong-vscode-extension/out/
mekong-vscode-extension/*.vsix
mekong-vscode-extension/.vscode-test/

# ══════════════════════════════════════════════════════════════════════════════
#  npm PACKAGE  (mekong-node-sdk/)
# ══════════════════════════════════════════════════════════════════════════════
mekong-node-sdk/node_modules/
mekong-node-sdk/.npmrc
mekong-node-sdk/npm-debug.log*

# ══════════════════════════════════════════════════════════════════════════════
#  PYTHON PACKAGE  (mekong-python-sdk/)
# ══════════════════════════════════════════════════════════════════════════════
mekong-python-sdk/dist/
mekong-python-sdk/build/
mekong-python-sdk/*.egg-info/
mekong-python-sdk/src/*.egg-info/
mekong-python-sdk/__pycache__/
mekong-python-sdk/**/__pycache__/
mekong-python-sdk/**/*.pyc
mekong-python-sdk/.venv/
mekong-python-sdk/venv/
mekong-python-sdk/.pytest_cache/

# ══════════════════════════════════════════════════════════════════════════════
#  GITHUB ACTIONS  (allow workflows, ignore everything else)
# ══════════════════════════════════════════════════════════════════════════════
.github/*
!.github/workflows/
!.github/workflows/*.yml
!.github/examples/
!.github/examples/*.example

# ══════════════════════════════════════════════════════════════════════════════
#  CHECKSUMS (generated per release — add manually with: git add -f SHA256SUMS-vX.Y.Z.txt)
# ══════════════════════════════════════════════════════════════════════════════
SHA256SUMS-*.txt

# ══════════════════════════════════════════════════════════════════════════════
#  macOS
# ══════════════════════════════════════════════════════════════════════════════
.DS_Store
.AppleDouble
.LSOverride

# ══════════════════════════════════════════════════════════════════════════════
#  EDITORS / IDEs
# ══════════════════════════════════════════════════════════════════════════════
.vscode/
.idea/
*.swp
*.swo
*~

# ══════════════════════════════════════════════════════════════════════════════
#  CLAUDE
# ══════════════════════════════════════════════════════════════════════════════
.claude/
.cluade/
log
