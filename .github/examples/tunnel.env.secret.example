# GitHub Environment secret: TUNNEL_ENV_FILE
#
# Paste the full content of your real tunnel server env file into the GitHub
# secret named TUNNEL_ENV_FILE.
#
# This file is a safe template only. Replace placeholder values before use.

DOMAIN=proxy.angkorsearch.dev
SSH_ADDR=:22
HTTP_ADDR=127.0.0.1:8081
HTTPS_ADDR=127.0.0.1:8443
STATS_ADDR=127.0.0.1:9090

HOST_KEY_PATH=/opt/mekongtunnel/host_key
TLS_CERT=/etc/letsencrypt/live/proxy.angkorsearch.dev/fullchain.pem
TLS_KEY=/etc/letsencrypt/live/proxy.angkorsearch.dev/privkey.pem

DATABASE_URL=postgres://CHANGE_ME_USER:CHANGE_ME_PASSWORD@CHANGE_ME_DB_HOST:5432/CHANGE_ME_DB_NAME?sslmode=disable

# Optional Redis for multi-instance cache/pubsub/rate limit support.
# Leave REDIS_URL unset if you are still running a single API instance and a
# single tunnel edge.
REDIS_URL=redis://127.0.0.1:6379/0
REDIS_PREFIX=mekong
REDIS_CACHE_TTL=30s
REDIS_DOMAIN_CACHE_TTL=1m

MAX_TUNNELS_PER_IP=1000
MAX_TOTAL_TUNNELS=0
MAX_CONNECTIONS_PER_MINUTE=0
REQUESTS_PER_SECOND=0
BURST_SIZE=0
RATE_LIMIT_VIOLATIONS_MAX=0
BLOCK_DURATION=0s
MAX_REQUEST_BODY_MB=1024
MAX_RESPONSE_BODY_MB=1024
MAX_WEBSOCKET_TRANSFER_MB=0
